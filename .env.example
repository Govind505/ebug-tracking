# eBug Tracking — Environment Configuration
# Copy to .env and fill in values

# ── General ──
EBUG_DEV_MODE=true
NODE_ENV=development

# ── NATS ──
NATS_URL=nats://localhost:4222

# ── PostgreSQL ──
DATABASE_URL=postgres://ebug:ebug@localhost:5432/ebug?sslmode=disable

# ── S3/MinIO ──
S3_BUCKET=ebug-storage
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=ebugadmin
AWS_SECRET_ACCESS_KEY=ebugadmin123

# ── Vector Database ──
VECTOR_DB_TYPE=milvus
VECTOR_DB_URL=http://localhost:19530
# PINECONE_API_KEY=
# PINECONE_INDEX=ebug-bugs

# ── AI / Embeddings ──
# OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
SIMILARITY_THRESHOLD=0.92

# ── LLM (Root Cause Analysis) ──
LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# ── Auth (OIDC) ──
# OIDC_ISSUER=https://auth.ebug.dev
# OIDC_CLIENT_ID=ebug-api
# OIDC_AUDIENCE=ebug-api
# JWKS_URL=https://auth.ebug.dev/.well-known/jwks.json
JWT_SECRET=ebug-dev-secret

# ── WebSocket Hub ──
WS_HUB_PORT=8082

# ── API Gateway ──
PORT=8090
LOG_LEVEL=info

# ── Ingestion Worker ──
WORKER_COUNT=5
BATCH_SIZE=100
FLUSH_TIMEOUT_MS=1000

