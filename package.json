{
  "name": "ebug-tracking",
  "version": "0.1.0",
  "private": true,
  "description": "Universal Quality Fabric — Cloud-Native AI Bug Tracking Ecosystem",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*",
    "plugins/*"
  ],
  "scripts": {
    "proto:gen": "node scripts/proto-gen.mjs",
    "dev": "docker compose up -d",
    "dev:stop": "docker compose down",
    "build:all": "npm run -ws build",
    "lint": "npm run -ws lint",
    "test": "npm run -ws test",
    "test:e2e": "node scripts/e2e-test.mjs",
    "vsce:package": "cd plugins/vscode && npm run vsce:package",
    "clean": "npm run -ws clean"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@bufbuild/buf": "^1.30.0",
    "@bufbuild/protoc-gen-es": "^1.9.0",
    "@connectrpc/protoc-gen-connect-es": "^1.4.0",
    "prettier": "^3.3.0",
    "eslint": "^9.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
